---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrevious from "@components/BackToPrevious.astro";
import PostNavigation from "@components/PostNavigation.astro";
import TableOfContents from "@components/TableOfContents.astro";
import Giscus from "@components/Giscus.astro";
import { PT } from "@components/PortableText";
import { client, blogPostsAllQuery, blogPostQuery, type SanityPost, type BlockContent } from "@lib/sanity";

export async function getStaticPaths() {
  const posts = await client.fetch(blogPostsAllQuery);
  return posts
    .filter((post: SanityPost) => !post.draft)
    .map((post: SanityPost) => ({
      params: { id: post.slug },
    }));
}

const { id } = Astro.params;
if (!id) throw new Error("Missing id param");

const post = await client.fetch(blogPostQuery, { slug: id });
if (!post) throw new Error(`Blog entry not found: ${id}`);

const allPosts = await client.fetch(blogPostsAllQuery);
const publishedPosts = allPosts.filter((p: SanityPost) => !p.draft);

function getNextPost() {
  const idx = publishedPosts.findIndex((p: SanityPost) => p.slug === id);
  return publishedPosts[idx - 1];
}

function getPrevPost() {
  const idx = publishedPosts.findIndex((p: SanityPost) => p.slug === id);
  return publishedPosts[idx + 1];
}

const nextPost = getNextPost();
const prevPost = getPrevPost();

function extractHeadings(content: unknown[]): Array<{ depth: number; id: string; text: string }> {
  const headings: Array<{ depth: number; id: string; text: string }> = [];
  if (!Array.isArray(content)) return headings;
  for (const block of content) {
    const b = block as BlockContent;
    if (b._type === "block") {
      const style = b.style || "normal";
      const depth = style === "h2" ? 1 : style === "h3" ? 2 : style === "h4" ? 3 : 0;
      if (depth > 0) {
        const text = b.children?.map((c: { text?: string }) => c.text || "").join("") || "";
        const id = `h-${b._key}`;
        headings.push({ depth, id, text });
      }
    }
  }
  return headings;
}

const headings = extractHeadings(post.content || []);
const bodyText = post.content ? JSON.stringify(post.content) : "";
---

<Layout title={post.title} description={post.description}>
  <Container>
    <div class="animate">
      <BackToPrevious href="/blog">Back to blog</BackToPrevious>
    </div>
    <div class="my-6 sm:my-10 space-y-1">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={new Date(post.date)} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(bodyText)}
        </div>
      </div>
      <h1 class="animate text-2xl sm:text-3xl font-semibold text-black dark:text-white">
        {post.title}
      </h1>
      {
        post.tags && post.tags?.length > 0 ? (
          <div class="animate flex gap-2 pt-1">
            {post.tags.map((tag: string) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-sm border border-black/15 px-2 py-1 text-sm transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/20 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
              >
                {tag}
              </a>
            ))}
          </div>
        ) : null
      }
    </div>
    {headings.length > 0 && <TableOfContents headings={headings} />}
    <article class="animate">
      {post.content && <PT value={post.content} />}
      <div class="mt-12 sm:mt-24">
        <PostNavigation prevPost={prevPost} nextPost={nextPost} />
      </div>
      <div class="mt-12 sm:mt-24">
        <Giscus />
      </div>
    </article>
  </Container>
</Layout>
