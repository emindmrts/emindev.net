---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrevious from "@components/BackToPrevious.astro";
import Link from "@components/Link.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { PT } from "@components/PortableText";
import { client, projectsAllQuery, projectQuery, type SanityProject, type BlockContent } from "@lib/sanity";

export async function getStaticPaths() {
  const projects = await client.fetch(projectsAllQuery);
  return projects
    .filter((p: SanityProject) => !p.draft)
    .map((project: SanityProject) => ({
      params: { id: project.slug },
    }));
}

const { id } = Astro.params;
if (!id) throw new Error("Missing id param");

const project = await client.fetch(projectQuery, { slug: id });
if (!project) throw new Error(`Project not found: ${id}`);

function extractHeadings(content: unknown[]): Array<{ depth: number; id: string; text: string }> {
  const headings: Array<{ depth: number; id: string; text: string }> = [];
  if (!Array.isArray(content)) return headings;
  for (const block of content) {
    const b = block as BlockContent;
    if (b._type === "block") {
      const style = b.style || "normal";
      const depth = style === "h2" ? 1 : style === "h3" ? 2 : style === "h4" ? 3 : 0;
      if (depth > 0) {
        const text = b.children?.map((c: { text?: string }) => c.text || "").join("") || "";
        const id = `h-${b._key}`;
        headings.push({ depth, id, text });
      }
    }
  }
  return headings;
}

const headings = extractHeadings(project.content || []);
const bodyText = project.content ? JSON.stringify(project.content) : "";
---

<Layout title={project.title} description={project.description}>
  <Container>
    <div class="animate">
      <BackToPrevious href="/projects">Back to projects</BackToPrevious>
    </div>
    <div class="animate my-10 space-y-1">
      <div class="flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={new Date(project.date)} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(bodyText)}
        </div>
      </div>
      <h1 class="text-3xl font-semibold text-black dark:text-white">
        {project.title}
      </h1>
      {
        (project.demoURL || project.repoURL) && (
          <nav class="flex gap-1">
            {project.demoURL && (
              <Link href={project.demoURL} external>
                demo
              </Link>
            )}
            {project.demoURL && project.repoURL && <span>/</span>}
            {project.repoURL && (
              <Link href={project.repoURL} external>
                repo
              </Link>
            )}
          </nav>
        )
      }
    </div>
    {headings.length > 0 && <TableOfContents headings={headings} />}
    <article class="animate">
      {project.content && <PT value={project.content} />}
    </article>
  </Container>
</Layout>
