---
import Layout from "@layouts/Layout.astro";
import HomeContainer from "@components/HomeContainer.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import vinylImg from "@assets/vinyl.png";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects: CollectionEntry<"projects">[] = (
  await getCollection("projects")
)
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const techStack = [
  { name: "TypeScript", icon: "typescript" },
  { name: "JavaScript", icon: "javascript" },
  { name: "React", icon: "react" },
  { name: "Next.js", icon: "nextdotjs" },
  { name: "Node.js", icon: "nodedotjs" },
  { name: "GitHub", icon: "github" },
  { name: "VS Code", icon: "visualstudiocode" },
  { name: "Prisma", icon: "prisma" },
  { name: "Figma", icon: "figma" },
  { name: "Tailwind CSS", icon: "tailwindcss" },
  { name: "AWS", icon: "amazonwebservices" },
  { name: "Redis", icon: "redis" },
  { name: "MySQL", icon: "mysql" },
  { name: "Supabase", icon: "supabase" },
];
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <div class="ambient-glow-left"></div>
  <div class="ambient-glow-right"></div>
  
  <HomeContainer>
    <aside data-pagefind-ignore>
      <div class="lg:grid lg:grid-cols-12 lg:gap-12 space-y-16 lg:space-y-0">
        
        <!-- LEFT COLUMN: Profile & Status -->
        <div class="lg:col-span-3 space-y-8">
          <section class="animate">
            <h1 class="text-2xl font-semibold text-primary">
              hiya! i'm emin
            </h1>
            <p class="mt-3 text-sm text-muted">
              junior web developer · building things on the web
            </p>
            
            <div class="mt-8 space-y-4">
              <h3 class="text-xs font-semibold uppercase tracking-wider text-ghost">Tech Stack</h3>
              <div class="flex flex-wrap gap-1.5">
                {
                  techStack.map((tech) => (
                    <div 
                      class="flex items-center gap-1.5 text-[11px] px-2 py-1 rounded border border-white/5 cursor-default text-primary mi-lift" 
                      style="background-color: var(--bg-subtle); opacity: 0.85;"
                      title={tech.name}
                    >
                      <img 
                        src={`https://cdn.simpleicons.org/${tech.icon}/white`} 
                        alt={tech.name} 
                        class="w-3.5 h-3.5 opacity-80" 
                        loading="lazy"
                      />
                      <span>{tech.name}</span>
                    </div>
                  ))
                }
              </div>
            </div>
          </section>
        </div>

        <!-- CENTER COLUMN: Content (Blog & Projects) -->
        <div class="lg:col-span-6 space-y-12">
          <section class="animate space-y-6">
            <div class="flex flex-wrap items-center justify-between gap-y-2">
              <h2 class="text-sm font-semibold uppercase tracking-wider text-faint">
                writing
              </h2>
              <Link href="/blog"> See all posts </Link>
            </div>
            <ul class="not-prose flex flex-col gap-4">
              {
                blog.map((post) => (
                  <li>
                    <ArrowCard entry={post} />
                  </li>
                ))
              }
            </ul>
          </section>

          <section class="animate space-y-6">
            <div class="flex flex-wrap items-center justify-between gap-y-2">
              <h2 class="text-sm font-semibold uppercase tracking-wider text-faint">
                projects
              </h2>
              <Link href="/projects"> See all projects </Link>
            </div>
            <ul class="not-prose flex flex-col gap-4">
              {
                projects.map((project) => (
                  <li>
                    <ArrowCard entry={project} />
                  </li>
                ))
              }
            </ul>
          </section>
        </div>

        <!-- RIGHT COLUMN: Widgets & Socials -->
        <div class="lg:col-span-3 space-y-8">
          <section class="animate space-y-4 lg:sticky lg:top-24">
            
            <!-- Now Playing Widget -->
            <div 
              id="now-playing-widget" 
              class="flex items-center gap-3 px-4 py-3 rounded-lg border border-white/8 transition-all hover:bg-white/5 hover:border-white/15 cursor-pointer" 
              style="background-color: var(--bg-subtle);"
            >
              <audio id="np-audio" preload="auto"></audio>
              <div id="np-cover-wrap" class="flex-shrink-0 relative size-10 z-10">
                <img id="np-cover" src="" alt="Album cover" class="size-full rounded relative z-10 object-cover hidden" />
                <div id="np-cover-placeholder" class="size-full rounded flex items-center justify-center relative z-10" style="background-color: var(--bg-hover);">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="opacity: 0.3;">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m9 19 3-3m0 0 3 3m-3-3V6a1 1 0 0 1 1-1h5" />
                  </svg>
                </div>
                <!-- Vinyl record peeking out -->
                <div id="np-vinyl-wrapper" class="absolute top-0.5 left-0.5 size-9 z-20 hidden cursor-grab active:cursor-grabbing" style="touch-action: none;">
                  <img id="np-vinyl" src={vinylImg.src} alt="Vinyl" class="size-full rounded-full object-contain pointer-events-none select-none" draggable="false" />
                </div>
              </div>
              <div id="np-info" class="flex-1 min-w-0 cursor-pointer">
                <div class="flex items-center gap-2 mb-0.5">
                  <span id="np-label" class="text-xs uppercase tracking-wider text-ghost">not playing</span>
                  <span id="np-bars" class="hidden flex gap-0.5 items-end h-3">
                    <span class="w-0.5 rounded-full bg-green-400" style="height: 40%; animation: npBar 0.8s ease-in-out infinite alternate;"></span>
                    <span class="w-0.5 rounded-full bg-green-400" style="height: 80%; animation: npBar 0.8s ease-in-out 0.2s infinite alternate;"></span>
                    <span class="w-0.5 rounded-full bg-green-400" style="height: 60%; animation: npBar 0.8s ease-in-out 0.4s infinite alternate;"></span>
                  </span>
                </div>
                <div id="np-title" class="text-sm font-medium truncate hidden text-primary"></div>
                <div id="np-artist" class="text-xs truncate hidden text-faint"></div>
              </div>
            </div>

            <!-- Connect -->
            <div class="pt-6">
              <h2 class="text-xs font-semibold uppercase tracking-wider mb-4 text-ghost">
                connect
              </h2>
              <div class="flex flex-col gap-2">
                {
                  SOCIALS.map((SOCIAL) => {
                    const nameLower = SOCIAL.NAME.toLowerCase();
                    const iconUrl = nameLower.includes("github") 
                      ? "https://cdn.simpleicons.org/github/white" 
                      : nameLower.includes("instagram")
                        ? "https://cdn.simpleicons.org/instagram/white"
                        : (nameLower.includes("twitter") || nameLower.includes("x"))
                          ? "https://cdn.simpleicons.org/x/white"
                          : null;
                    return (
                      <a
                        href={SOCIAL.HREF}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                        class="group flex items-center justify-between px-3 py-2.5 rounded-lg border border-white/5 transition-all duration-300 hover:bg-white/5 hover:border-white/10 mi-glow"
                        style="background-color: var(--bg-subtle);"
                      >
                        <div class="flex items-center gap-2.5">
                          {iconUrl ? (
                            <img src={iconUrl} alt={SOCIAL.NAME} class="w-4 h-4 opacity-60 group-hover:opacity-100 transition-opacity" />
                          ) : (
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 group-hover:opacity-100 transition-opacity text-primary"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                          )}
                          <span class="text-sm font-medium text-primary">{SOCIAL.NAME}</span>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-30 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-1 group-hover:-translate-y-1 text-primary"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                      </a>
                    );
                  })
                }
                <a
                  href={`mailto:${SITE.EMAIL}`}
                  aria-label={`Email ${SITE.TITLE}`}
                  class="group flex items-center justify-between px-3 py-2.5 rounded-lg border border-white/5 transition-all duration-300 hover:bg-white/5 hover:border-white/10 mt-1 mi-glow"
                  style="background-color: var(--bg-subtle);"
                >
                  <div class="flex items-center gap-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 group-hover:opacity-100 transition-opacity text-primary"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    <span class="text-sm font-medium text-primary">Email Me</span>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-30 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-1 text-primary"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            </div>
          </section>
        </div>

      </div>
    </aside>
  </HomeContainer>
</Layout>

<style>
  @keyframes npBar {
    from { transform: scaleY(0.4); }
    to   { transform: scaleY(1); }
  }
</style>

<script is:inline data-discord-id="1133067172298633336">
  (() => {
    const DISCORD_ID = document.querySelector("script[data-discord-id]")?.getAttribute("data-discord-id") || "";

    function getElements() {
      return {
        label: document.getElementById("np-label"),
        bars: document.getElementById("np-bars"),
        cover: document.getElementById("np-cover"),
        placeholder: document.getElementById("np-cover-placeholder"),
        title: document.getElementById("np-title"),
        artist: document.getElementById("np-artist"),
        widget: document.getElementById("now-playing-widget"),
        vinylWrap: document.getElementById("np-vinyl-wrapper"),
        vinyl: document.getElementById("np-vinyl"),
        audio: document.getElementById("np-audio"),
      };
    }

    function setNotPlaying(els) {
      if (!els) els = getElements();
      if (els.label) els.label.textContent = "not playing";
      if (els.bars) els.bars.classList.add("hidden");
      if (els.cover) { els.cover.classList.add("hidden"); els.cover.src = ""; }
      if (els.placeholder) els.placeholder.classList.remove("hidden");
      if (els.title) { els.title.classList.add("hidden"); els.title.textContent = ""; }
      if (els.artist) { els.artist.classList.add("hidden"); els.artist.textContent = ""; }
      if (els.widget) els.widget.removeAttribute("data-href");
      if (els.audio) { els.audio.pause(); els.audio.removeAttribute("src"); }
      if (els.vinylWrap) {
        els.vinylWrap.classList.add("hidden");
      }
    }

    async function fetchNowPlaying() {
      const els = getElements();
      if (!els.label) return;

      try {
        const res = await fetch(`https://api.lanyard.rest/v1/users/${DISCORD_ID}`);
        if (!res.ok) { setNotPlaying(els); return; }
        const data = await res.json();
        if (!data.success) { setNotPlaying(els); return; }

        const spotify = data.data?.spotify;

        if (spotify) {
          els.label.textContent = "now playing";
          if (els.bars) { els.bars.classList.remove("hidden"); els.bars.style.display = "flex"; }
          if (els.cover) { els.cover.src = spotify.album_art_url; els.cover.classList.remove("hidden"); }
          if (els.placeholder) els.placeholder.classList.add("hidden");
          if (els.title) { els.title.textContent = spotify.song; els.title.classList.remove("hidden"); }
          if (els.artist) { els.artist.textContent = spotify.artist; els.artist.classList.remove("hidden"); }
          if (els.widget) els.widget.setAttribute("data-href", `https://open.spotify.com/track/${spotify.track_id}`);
          if (els.vinylWrap) els.vinylWrap.classList.remove("hidden");
          
          if (els.audio && !els.audio.src) {
            try {
              const apiRes = await fetch(`/api/spotify?track_id=${spotify.track_id}`);
              if (apiRes.ok) {
                const apiData = await apiRes.json();
                if (apiData.previewUrl) {
                  els.audio.src = apiData.previewUrl;
                }
              }
            } catch (e) {
              console.warn("[NowPlaying] Backend fetch error:", e);
            }
          }
        } else {
          setNotPlaying(els);
        }
      } catch (e) {
        console.warn("[NowPlaying] fetch error:", e);
        setNotPlaying(els);
      }
    }

    let intervalId = null;

    function handleMouseEnter() {
      const audio = document.getElementById("np-audio");
      if (audio && audio.src) {
        audio.volume = 0.5; // Soft volume for background
        audio.play().catch(e => console.log("Autoplay prevented:", e));
      }
    }

    function handleMouseLeave() {
      const audio = document.getElementById("np-audio");
      if (audio) {
        audio.pause();
      }
    }

    let vinylState = {
      isDragging: false,
      currentAngle: 0,
      lastPointerAngle: 0,
      lastTime: 0,
      angularVelocity: 0
    };

    let scratchController = null;

    function setupVinylScratch() {
      const vinylWrap = document.getElementById("np-vinyl-wrapper");
      const vinyl = document.getElementById("np-vinyl");
      const audio = document.getElementById("np-audio");
      const widget = document.getElementById("now-playing-widget");
      const npInfo = document.getElementById("np-info");
      
      if (!vinylWrap || !vinyl || !audio) return;

      if (scratchController) scratchController.abort();
      scratchController = new AbortController();
      const opts = { signal: scratchController.signal };

      let cx, cy;
      let currentRate = 1.0;
      let loopId = null;

      // Open Spotify only when clicking the text/info area, not the vinyl
      if (npInfo) {
        npInfo.addEventListener("click", () => {
          const href = widget?.getAttribute("data-href");
          if (href) window.open(href, "_blank", "noopener,noreferrer");
        }, opts);
      }

      function getPointerAngle(e) {
        return Math.atan2(e.clientY - cy, e.clientX - cx);
      }

      function onPointerDown(e) {
        if (!audio.src) return;
        e.preventDefault();
        e.stopPropagation();
        
        vinylState.isDragging = true;
        vinyl.classList.add("is-dragging");
        
        const rect = vinylWrap.getBoundingClientRect();
        cx = rect.left + rect.width / 2;
        cy = rect.top + rect.height / 2;

        vinylState.lastPointerAngle = getPointerAngle(e);
        vinylState.lastTime = performance.now();
        vinylState.angularVelocity = 0;
        
        vinylWrap.setPointerCapture(e.pointerId);
        if (loopId) { cancelAnimationFrame(loopId); loopId = null; }
      }

      function onPointerMove(e) {
        if (!vinylState.isDragging) return;
        e.preventDefault();
        
        const angle = getPointerAngle(e);
        const now = performance.now();
        
        let delta = angle - vinylState.lastPointerAngle;
        // Normalize to [-PI, PI]
        if (delta > Math.PI) delta -= 2 * Math.PI;
        if (delta < -Math.PI) delta += 2 * Math.PI;

        const dt = (now - vinylState.lastTime) / 1000; // seconds
        
        if (dt > 0) {
          const deltaDeg = delta * (180 / Math.PI);
          vinylState.currentAngle += deltaDeg;
          vinyl.style.transform = `rotate(${vinylState.currentAngle}deg)`;
          
          // Smooth the velocity with exponential moving average
          const instantVelocity = delta / dt; // rad/s
          vinylState.angularVelocity = vinylState.angularVelocity * 0.6 + instantVelocity * 0.4;
          
          // Map angular velocity to playback rate
          const speed = Math.abs(vinylState.angularVelocity);
          const newRate = Math.min(4.0, Math.max(0.25, 1.0 + speed * 0.15));
          currentRate = newRate;
          
          if (!audio.paused) {
            audio.playbackRate = currentRate;
          }
        }
        
        vinylState.lastPointerAngle = angle;
        vinylState.lastTime = now;
      }
      
      function inertiaLoop() {
        if (vinylState.isDragging) return;
        
        // Decay angular velocity
        vinylState.angularVelocity *= 0.96;
        
        // Smoothly return playback rate to 1.0
        currentRate += (1.0 - currentRate) * 0.05;
        
        if (audio && !audio.paused) {
          audio.playbackRate = Math.max(0.25, Math.min(4.0, currentRate));
        }

        // Keep spinning visually based on remaining velocity
        const degPerFrame = vinylState.angularVelocity * (180 / Math.PI) * (1/60);
        vinylState.currentAngle += degPerFrame + 1.5; // 1.5 = base spin
        vinyl.style.transform = `rotate(${vinylState.currentAngle}deg)`;

        // Stop when settled
        if (Math.abs(currentRate - 1.0) < 0.005 && Math.abs(vinylState.angularVelocity) < 0.1) {
          if (audio && !audio.paused) audio.playbackRate = 1.0;
          currentRate = 1.0;
          vinyl.classList.remove("is-dragging");
          vinyl.style.transform = '';
          loopId = null;
          return;
        }
        
        loopId = requestAnimationFrame(inertiaLoop);
      }

      function onPointerUp(e) {
        if (!vinylState.isDragging) return;
        vinylState.isDragging = false;
        vinylWrap.releasePointerCapture(e.pointerId);
        
        // Start smooth deceleration loop
        if (!loopId) loopId = requestAnimationFrame(inertiaLoop);
      }

      vinylWrap.addEventListener("pointerdown", onPointerDown, opts);
      vinylWrap.addEventListener("pointermove", onPointerMove, opts);
      vinylWrap.addEventListener("pointerup", onPointerUp, opts);
      vinylWrap.addEventListener("pointercancel", onPointerUp, opts);
    }

    function init() {
      if (intervalId) { clearInterval(intervalId); intervalId = null; }
      setNotPlaying();
      fetchNowPlaying();
      intervalId = setInterval(fetchNowPlaying, 15000);
      
      const widget = document.getElementById("now-playing-widget");
      if (widget) {
        widget.removeEventListener("mouseenter", handleMouseEnter);
        widget.removeEventListener("mouseleave", handleMouseLeave);
        widget.addEventListener("mouseenter", handleMouseEnter);
        widget.addEventListener("mouseleave", handleMouseLeave);
      }
      
      setupVinylScratch();
    }

    document.addEventListener("astro:page-load", init);
    document.addEventListener("astro:before-swap", () => {
      if (intervalId) { clearInterval(intervalId); intervalId = null; }
    });
  })();
</script>
